# ---- PostgreSQL (Supabase) ----
# App runtime: shared transaction-mode pooler (pgbouncer). Note the :6543 port + ?pgbouncer=true
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations: session-mode pooler (direct). Note the :5432 port
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
